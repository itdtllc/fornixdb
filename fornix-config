#!/usr/bin/env bash
# FornixDB configuration wizard — launcher for macOS / Linux (and Git Bash).
#
#   ./fornix-config                 # configure your store — NO arguments needed
#   ./fornix-config --db /other.db  # advanced: target a specific store
#
# No venv activation and no $FORNIXDB_DB needed. The wizard finds your store
# from the machine registry; if you have more than one it asks which to
# configure. Windows users: run fornix-config.cmd instead (double-clickable).
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Prefer the repo venv interpreter (it has the deps) on either layout, then fall
# back to a Python on PATH. -m fornixdb runs the package from this checkout.
py=""
for cand in "$here/.venv/bin/python" "$here/.venv/Scripts/python.exe"; do
    [ -x "$cand" ] && { py="$cand"; break; }
done
[ -n "$py" ] || py="$(command -v python3 || command -v python || true)"
[ -n "$py" ] || { echo "fornix-config: no Python interpreter found" >&2; exit 1; }

# Any passthrough args (e.g. --db) are GLOBAL options, so they precede the
# `configure` subcommand. With no args this is just: python -m fornixdb configure
exec env PYTHONPATH="$here${PYTHONPATH:+:$PYTHONPATH}" \
    "$py" -m fornixdb ${1+"$@"} configure
